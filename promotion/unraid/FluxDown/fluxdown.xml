<?xml version="1.0"?>
<Container version="2">
  <Name>FluxDown</Name>
  <Repository>ghcr.io/zerx-lab/fluxdown-server:0.1.54</Repository>
  <Registry>https://ghcr.io/zerx-lab/fluxdown-server</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/zerx-lab/FluxDown/issues</Support>
  <Project>https://github.com/zerx-lab/FluxDown</Project>
  <Overview>
    A blazing fast, multi-protocol download manager powered by a Rust engine.
    Supports HTTP/HTTPS/FTP/BitTorrent/HLS with intelligent segmentation, resume,
    speed control, a browser extension, aria2-compatible JSON-RPC and an MCP endpoint.
    A free alternative to Internet Download Manager and aria2.
    NOTE: first launch prints a one-time admin token in the container log
    (grep -i token). The management API and MCP endpoint require this token.
  </Overview>
  <Category>Downloaders: Network:Web</Category>
  <WebUI>http://[IP]:[PORT:17800]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/zerx-lab/unraid-templates/main/FluxDown/fluxdown.xml</TemplateURL>
  <Icon>https://cdn.jsdelivr.net/gh/zerx-lab/FluxDown@main/assets/logo/fluxdown_logo.svg</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>
    A blazing fast, multi-protocol download manager powered by a Rust engine
    (HTTP/HTTPS/FTP/BitTorrent/HLS). Web UI on port 17800.
  </Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>17800</HostPort>
        <ContainerPort>17800</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/fluxdown/data</HostDir>
      <ContainerDir>/data</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/downloads</HostDir>
      <ContainerDir>/root/Downloads</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>Etc/UTC</Value>
      <Name>TZ</Name>
      <Mode/>
    </Variable>
  </Environment>
  <Config Name="WebUI Port" Target="17800" Default="17800" Mode="tcp" Description="FluxDown Web UI / REST API / WebSocket" Type="Port" Display="always" Required="true" Mask="false">17800</Config>
  <Config Name="Data" Target="/data" Default="/mnt/user/appdata/fluxdown/data" Mode="rw" Description="Database, logs and admin token" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/fluxdown/data</Config>
  <Config Name="Downloads" Target="/root/Downloads" Default="/mnt/user/downloads" Mode="rw" Description="Default download directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/downloads</Config>
  <Config Name="TZ" Target="TZ" Default="Etc/UTC" Mode="" Description="Timezone" Type="Variable" Display="advanced" Required="false" Mask="false">Etc/UTC</Config>
</Container>
