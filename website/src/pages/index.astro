---
import Layout from "../layouts/Layout.astro";
import { FloatingNavbar } from "../components/ui/floating-navbar";
import AnnouncementBar from "../components/AnnouncementBar";
import HeroSection from "../components/HeroSection";
import FeaturesSection from "../components/FeaturesSection";
import ExtensionSection from "../components/ExtensionSection";
import DownloadSection from "../components/DownloadSection";
import Footer from "../components/Footer";
---

<Layout>
  <AnnouncementBar client:load />
  <FloatingNavbar client:load />
  <main>
    <HeroSection client:load />
    <!-- Section divider: Hero → Features -->
    <div class="relative h-px w-full">
      <div class="absolute inset-0 bg-gradient-to-r from-transparent via-brand-sky/30 to-transparent"></div>
      <div class="absolute left-1/2 -translate-x-1/2 -top-12 w-64 h-24 bg-brand-sky/[0.04] blur-3xl rounded-full pointer-events-none"></div>
    </div>
    <FeaturesSection client:visible />
    <!-- Section divider: Features → Extension -->
    <div class="relative h-px w-full">
      <div class="absolute inset-0 bg-gradient-to-r from-transparent via-brand-cyan/25 to-transparent"></div>
      <div class="absolute left-1/2 -translate-x-1/2 -top-12 w-64 h-24 bg-brand-cyan/[0.04] blur-3xl rounded-full pointer-events-none"></div>
    </div>
    <ExtensionSection client:visible />
    <!-- Section divider: Extension → Download -->
    <div class="relative h-px w-full">
      <div class="absolute inset-0 bg-gradient-to-r from-transparent via-brand-blue/25 to-transparent"></div>
      <div class="absolute left-1/2 -translate-x-1/2 -top-12 w-64 h-24 bg-brand-blue/[0.04] blur-3xl rounded-full pointer-events-none"></div>
    </div>
    <DownloadSection client:visible />
  </main>
  <Footer client:load />
</Layout>
