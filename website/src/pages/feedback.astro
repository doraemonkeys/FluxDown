---
import Layout from "../layouts/Layout.astro";
import { FloatingNavbar } from "../components/ui/floating-navbar";
import FeedbackPage from "../components/FeedbackPage";
import Footer from "../components/Footer";
import CommunityFloat from "../components/CommunityFloat";
---

<Layout title="Feedback - FluxDown" description="Submit feedback, feature requests, or bug reports for FluxDown download manager. Track issue progress, view responses, and help us improve.">
  <FloatingNavbar client:load />
  <main class="relative">
    <!-- Background ambiance -->
    <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute top-0 left-1/3 w-[500px] h-[300px] bg-brand-cyan/[0.03] blur-[120px] rounded-full"></div>
      <div class="absolute bottom-0 right-1/4 w-[400px] h-[300px] bg-brand-blue/[0.03] blur-[100px] rounded-full"></div>
    </div>
    <FeedbackPage client:load />
  </main>
  <Footer client:load />
  <CommunityFloat client:load />
</Layout>
